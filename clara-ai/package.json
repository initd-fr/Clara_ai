  },
  "type": "module",
  "scripts": {
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "analyze": "ANALYZE=true next build && open .next/analyze/client.html",
    "analyze:server": "ANALYZE=true next build && open .next/analyze/server.html",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "dev": "concurrently \"next dev\" \"tsx src/server/ws-standalone.ts\"",
    "dev:kill": "lsof -ti:3000 -ti:3001 | xargs kill -9 2>/dev/null; echo 'Ports 3000 et 3001 libérés (ou déjà libres).'",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "type": "tsc --noEmit",
    "test": "pnpm exec vitest run",
    "test:unit": "pnpm exec vitest run --dir src/__tests__/unit",
    "test:integration": "pnpm exec vitest run --dir src/__tests__/integration",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "start": "concurrently \"next start\" \"tsx src/server/ws-standalone.ts\"",
    "ws:prod": "tsx src/server/ws-standalone.ts",
    "email": "email dev"
  },
