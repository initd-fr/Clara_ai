# =============================================================================
# Clara AI — Fichier d'environnement commun (Clara + Archibald)
# Copier vers .env à la racine, remplir les valeurs, puis lancer : ./start.sh
# Ne pas commiter le fichier .env
# =============================================================================
# Les valeurs ci-dessous sont prévues pour la stack Docker (postgres, minio = noms des services).
# Pour un déploiement sur votre machine : remplacez par vos vrais secrets et clés API.

# --- Utilisateur par défaut (créé au premier lancement par start.sh) ---
# Renseigner ces valeurs pour personnaliser le compte de premier accès.
CLARA_DEFAULT_EMAIL=clara@clara.local
CLARA_DEFAULT_PASSWORD=claraai
CLARA_DEFAULT_FIRST_NAME=Clara
CLARA_DEFAULT_LAST_NAME=AI

# --- Clara (Next.js) ---
APP_NAME=Clara
NODE_ENV=production
DATABASE_URL=postgresql://clara:clara_secret@postgres:5432/clara
EMAIL_FROM=contact@votredomaine.com
SUPPORT_EMAIL=support@votredomaine.com
CONTACT_EMAIL=contact@votredomaine.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@votredomaine.com
MINIO_ENDPOINT=minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USESSL=0
NEXTAUTH_SECRET=remplacer_par_une_cle_secrete_32_caracteres_min
NEXTAUTH_URL=http://localhost:3000

# Clés API LLM (obligatoires pour le chat / RAG)
OPENAI_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Lien vers Archibald (même serveur Docker = http://archibald:8000)
ARCHIBALD_API_URL=http://archibald:8000
ARCHIBALD_API_KEY=change-me-meme-valeur-que-API_KEY

# --- Archibald (FastAPI) ---
ENV=production
API_KEY=change-me-meme-valeur-que-ARCHIBALD_API_KEY
CORS_ORIGINS='["http://localhost:3000","http://clara:3000","http://127.0.0.1:3000"]'
API_URL=http://localhost:3000
DATABASE_SCHEMA=public
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
MINIO_BUCKET_NAME=archibald

# Recherche web (Tavily)
TAVILY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SERPER_API_KEY=
